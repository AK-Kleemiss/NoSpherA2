{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(gdb) Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/NoSpherA2_Debug",
      "args": [
        "-cif", "olex2/Wfn_job/sucrose.cif",
		"-dmin", "0.9",
		"-wfn", "olex2/Wfn_job/sucrose.wfx",
		"-acc", "1", "-v",
        "-no-date"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/tests/sucrose_fchk_SF",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "python import sys; sys.path.insert(0, '/usr/share/gcc/python'); from libstdcxx.v6.printers import register_libstdcxx_printers; register_libstdcxx_printers(None)",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: Optimizer",
      "type": "python",
      "request": "launch",
      "program": "D:\\git\\NoSpherA2\\tests\\ECP_SF\\Atomic_densities\\Rb_fit_minimize.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "nodebug": true
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/git/NoSpherA2/Src",
      "program": "d:/git/NoSpherA2/Src/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}