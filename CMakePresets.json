{
  "version": 3,
  "configurePresets": [
    {
      "name": "base-options",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-${presetName}",
      "cacheVariables": {
        "WITH_CLANG_TIDY": "OFF",
        "WITH_OCC": "ON",
        "USE_CCACHE": "YES",
        "CCACHE_OPTIONS": "CCACHE_CPP2=true;CCACHE_SLOPPINESS=clang_index_store",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ENV_PATH": "${sourceDir}/mambaenv",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/Lib",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      }
    },
    {
      "name": "macos-base",
      "hidden": true,
      "inherits": "base-options",
      "cacheVariables": {
        "OpenMP_ROOT": "$env{HOMEBREW_PREFIX}/opt/libomp"
      }

    },
    {
      "name": "macos-debug",
      "inherits": "macos-base",
      "displayName": "macOS Debug (Clang)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-release",
      "inherits": "macos-base",
      "displayName": "macOS release (Clang)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "Debug",
      "inherits": "base-options",
      "displayName": "Debug (GCC/ccache)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "inherits": "base-options",
      "displayName": "Release (GCC)",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    }
  ],
  "testPresets": [
    {
      "name": "macos-release",
      "configurePreset": "macos-release",
      "description": "Run all NoSpherA2 tests on macOS",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      },
      "environment": {
        "OCC_DATA_PATH": "${sourceDir}/occ/share"
      }
    }
  ]
}


