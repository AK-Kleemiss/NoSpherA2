{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",

      "environment": {
        "PATH": "${sourceDir}/.mambaenv/env;${sourceDir}/.mambaenv/env/Library/bin;${sourceDir}/.mambaenv/env/Scripts;$penv{PATH}",

        "CMAKE_PREFIX_PATH": "${sourceDir}/.mambaenv/env",
        "PKG_CONFIG_PATH": "${sourceDir}/.mambaenv/env/Library/lib/pkgconfig;${sourceDir}/.mambaenv/env/Library/share/pkgconfig",

        "RUSTC": "${sourceDir}/.mambaenv/env/Library/bin/rustc.exe",

        "CMAKE_GENERATOR": "Ninja",
        "CMAKE_GENERATOR_x86_64_pc_windows_msvc": "Ninja",
        "CMAKE_GENERATOR_x86_64-pc-windows-msvc": "Ninja"
      },

      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/.mambaenv/env/Library/bin/ninja.exe",

        "Python3_EXECUTABLE": "${sourceDir}/.mambaenv/env/python.exe",
        "Python_EXECUTABLE": "${sourceDir}/.mambaenv/env/python.exe",

        "PKG_CONFIG_EXECUTABLE": "${sourceDir}/.mambaenv/env/Library/bin/pkg-config.exe",
        "CARGO_EXE": "${sourceDir}/.mambaenv/env/Library/bin/cargo.exe"
      }
    },
    {
      "name": "unix-base",
      "hidden": true,
      "generator": "Ninja",
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "environment": {
        "PATH": "${sourceDir}/.mambaenv/env/bin:$penv{PATH}",
        "CMAKE_PREFIX_PATH": "${sourceDir}/.mambaenv/env",
        "PKG_CONFIG_PATH": "${sourceDir}/.mambaenv/env/lib/pkgconfig:${sourceDir}/.mambaenv/env/share/pkgconfig",
        "RUSTC": "${sourceDir}/.mambaenv/env/bin/rustc"
      },
      "cacheVariables": {
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/.mambaenv/env/bin/ninja",
        "Python3_EXECUTABLE": "${sourceDir}/.mambaenv/env/bin/python",
        "Python_EXECUTABLE": "${sourceDir}/.mambaenv/env/bin/python",
        "PKG_CONFIG_EXECUTABLE": "${sourceDir}/.mambaenv/env/bin/pkg-config",
        "CARGO_EXE": "${sourceDir}/.mambaenv/env/bin/cargo"
      }
    },
    {
      "name": "release-windows",
      "displayName": "Release (Windows)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-windows",
      "displayName": "Debug (Windows)",
      "inherits": "windows-base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-unix",
      "displayName": "Release (Linux/macOS)",
      "inherits": "unix-base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug-unix",
      "displayName": "Debug (Linux/macOS)",
      "inherits": "unix-base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release-windows",
      "configurePreset": "release-windows",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "debug-windows",
      "configurePreset": "debug-windows",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "release-unix",
      "configurePreset": "release-unix",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "debug-unix",
      "configurePreset": "debug-unix",
      "inheritConfigureEnvironment": true
    }
  ],
  "testPresets": [
    {
      "name": "release-windows",
      "configurePreset": "release-windows",
      "inheritConfigureEnvironment": true,
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-windows",
      "configurePreset": "debug-windows",
      "inheritConfigureEnvironment": true,
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-unix",
      "configurePreset": "release-unix",
      "inheritConfigureEnvironment": true,
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-unix",
      "configurePreset": "debug-unix",
      "inheritConfigureEnvironment": true,
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
