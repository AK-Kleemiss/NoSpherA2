#THIS IS THE LINUX MAKEFILE#
RM := rm -f

COMP := g++
C_COMP := gcc

all: ../BasisSetConverter

# Define the two separate lists with appropriate endings
# OBJS is not defined here based on OBJ_NAMES, so leaving blank or removing if unused
OBJS :=

GCC_OPTS := -std=c++2b -O3 -c -fmessage-length=0 -fopenmp -static -MMD -MP

BASIS_OBJ_NAMES := basis_set_helper BasisSetConverter
# Append .o_basis to the names
BASIS_OBJS := $(addsuffix .o_basis,$(BASIS_OBJ_NAMES))

# Pattern rule: % matches the name (e.g. basis_set_helper)
# Target: basis_set_helper.o_basis
# Prereq: ../Src/basis_set_helper/basis_set_helper.cpp
%.o_basis: ../Src/basis_set_helper/%.cpp
	@echo 'Building file: $<'
	@${COMP} ${GCC_OPTS} -MF"$(@:.o_basis=.d)" -MT"$@" -o "$@" "$<"
	@echo 'Finished building: $<'

#Basis set converter
../BasisSetConverter: ${BASIS_OBJS}
	@echo 'Linking BasisSetConverter'
	@${COMP} -fopenmp -static -o "BasisSetConverter" ${BASIS_OBJS}
	@mv BasisSetConverter ../
	@echo 'Done building basis_set_helper'

clean:
	@echo "Cleaning up"
	@${RM} $(BASIS_OBJS) $(BASIS_OBJS:.o_basis=.d) ../BasisSetConverter ../Src/auxiliary_basis.cpp ../Src/checkpoint.txt
	@echo "Cleaned up"

.PHONY: all clean basis_set_converter
.SECONDARY:
