<?xml version="1.0" encoding="UTF-8"?>
<!--
  VS Test / vstest.console code-coverage settings for NoSpherA2.
  Usage:
    vstest.console.exe Windows\x64\Profile\Tests.dll /Platform:x64 /Settings:Windows\coverage.runsettings /EnableCodeCoverage
  Or in the VS IDE: Test > Configure Run Settings > Select Solution-Wide runsettings File.

  Only NoSpherA2_DLL.dll (which contains all Src/ compiled code) and Tests.dll
  are included in the coverage report.  All third-party libraries (OCC, TBB, MKL,
  featomic, libcint …) are excluded so the report reflects project code only.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector
        friendlyName="Code Coverage"
        uri="datacollector://microsoft/CodeCoverage/2.0"
        assemblyQualifiedName="Microsoft.VisualStudio.Coverage.DynamicCoverageDataCollector, Microsoft.VisualStudio.TraceCollector, Version=11.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
        <Configuration>
          <CodeCoverage>
            <!--
              ModulePaths: which DLLs/EXEs the coverage engine instruments.
              The production logic lives in NoSpherA2_DLL.dll; the tests live in Tests.dll.
              Both must be built with /PROFILE (Profile|x64 configuration).
            -->
            <ModulePaths>
              <Include>
                <ModulePath>.*\\NoSpherA2_DLL\.dll</ModulePath>
                <ModulePath>.*\\Tests\.dll</ModulePath>
              </Include>
              <Exclude>
                <!-- Skip all third-party and OS DLLs -->
                <ModulePath>.*\\tbb.*\.dll</ModulePath>
                <ModulePath>.*\\mkl.*\.dll</ModulePath>
                <ModulePath>.*\\libiomp.*\.dll</ModulePath>
                <ModulePath>.*\\featomic.*\.dll</ModulePath>
                <ModulePath>.*\\metatensor.*\.dll</ModulePath>
                <ModulePath>.*\\vstest.*\.exe</ModulePath>
                <ModulePath>.*\\testhost.*\.exe</ModulePath>
              </Exclude>
            </ModulePaths>
            <!--
              Sources: filter the source files shown in the VS coverage report.
              Include only our own Src/ and NoSpherA2_DLL/ source trees.
            -->
            <Sources>
              <Include>
                <Source>.*\\Src\\.*</Source>
                <Source>.*\\NoSpherA2_DLL\\.*</Source>
                <Source>.*\\Windows\\Tests\\.*</Source>
              </Include>
              <Exclude>
                <Source>.*\\occ\\.*</Source>
                <Source>.*\\featomic.*\\.*</Source>
                <Source>.*\\libcint.*\\.*</Source>
                <Source>.*\\mdspan.*\\.*</Source>
                <Source>.*\\Lib\\.*</Source>
              </Exclude>
            </Sources>
            <!-- Collect branch coverage in addition to line coverage -->
            <UseVerifiableInstrumentation>False</UseVerifiableInstrumentation>
            <AllowLowIntegrityProcesses>True</AllowLowIntegrityProcesses>
            <CollectFromChildProcesses>True</CollectFromChildProcesses>
            <CollectAspDotNet>false</CollectAspDotNet>
          </CodeCoverage>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>

  <!-- Keep the test runner from hiding stdout so our log messages remain visible -->
  <TestRunParameters />

  <RunConfiguration>
    <ResultsDirectory>.\TestResults</ResultsDirectory>
    <TargetPlatform>x64</TargetPlatform>
  </RunConfiguration>
</RunSettings>
