  <Target Name="RunBasisSetConverterIfNeeded" BeforeTargets="PreBuildEvent">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(ProjectDir)run_basis_converter_if_needed.ps1&quot; -ConverterExe &quot;$(ProjectDir)..\Lib\BasisSetConverter.exe&quot; -SolutionDir &quot;$(MSBuildProjectDirectory)&quot; -Configuration &quot;$(Configuration)&quot; -Platform &quot;$(Platform)&quot; -PlatformToolset &quot;$(PlatformToolset)&quot; -MSBuildExe &quot;$(MSBuildBinPath)\MSBuild.exe&quot;" />
  </Target>
  <Target Name="CopyIntelOpenMP" AfterTargets="Build">
    <!-- Copy if it exists -->
    <Message Text="Copying Intel OpenMP runtime: $(IompDll) -&gt; $(TargetDir)" Importance="High" Condition="Exists('$(IompDll)')" />
    <Copy SourceFiles="$(IompDll)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="Exists('$(IompDll)')" />
    <!-- If missing, fail with a clear message (optional but recommended) -->
    <Error Condition="!Exists('$(IompDll)')" Text="Could not find libiomp5.dll at $(IompDll). Check MKLROOT or oneAPI compiler install." />
  </Target>
  <Target Name="CopyOccTbb" AfterTargets="Build">
    <PropertyGroup>
      <OccTbbDll>$(MSBuildProjectDirectory)\..\Lib\occ\bin\tbb12.dll</OccTbbDll>
    </PropertyGroup>
    <Copy SourceFiles="$(OccTbbDll)" DestinationFolder="$(TargetDir)" SkipUnchangedFiles="true" Condition="Exists('$(OccTbbDll)')" />
    <Error Condition="!Exists('$(OccTbbDll)')" Text="Could not find tbb12.dll at $(OccTbbDll). Build and install OCC first." />
  </Target>
